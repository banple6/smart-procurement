APP_ENV=loadtest
LOAD_TEST_ALLOWED=true
DATA_NAMESPACE=LOADTEST

DATABASE_PATH=/app/loadtest-data/loadtest.db
UPLOAD_DIR=/app/loadtest-uploads
PRIVATE_UPLOAD_DIR=/app/loadtest-private-uploads
BACKUP_DIR=/app/loadtest-backups
APP_UPDATE_RELEASE_DIR=/app/loadtest-releases

APP_SECRET=replace-with-independent-loadtest-secret
INITIAL_ADMIN_USERNAME=LOADTEST_BOOTSTRAP_ADMIN
INITIAL_ADMIN_PASSWORD=replace-with-independent-bootstrap-password
LOADTEST_USER_PASSWORD=replace-with-independent-loadtest-user-password

WEB_SESSION_IDLE_MINUTES=30
WEB_SESSION_ABSOLUTE_HOURS=8
WEB_QR_TTL_SECONDS=120
