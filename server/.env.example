APP_ENV=production
APP_SECRET=
SESSION_HOURS=72
DATABASE_PATH=/app/data/smart_procurement.db
UPLOAD_DIR=/app/uploads
PRIVATE_UPLOAD_DIR=/app/private_uploads
MAX_UPLOAD_MB=5
INITIAL_ADMIN_USERNAME=
INITIAL_ADMIN_PASSWORD=
BACKUP_DIR=/app/backups
JPUSH_ENABLED=false
JPUSH_APP_KEY=
JPUSH_MASTER_SECRET=
JPUSH_API_URL=https://api.jpush.cn/v3/push
JPUSH_TIMEOUT_SECONDS=8
JPUSH_MAX_ATTEMPTS=5
JPUSH_WORKER_POLL_SECONDS=5
JPUSH_PROCESSING_TIMEOUT_SECONDS=300
